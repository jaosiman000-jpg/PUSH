# ============================================================
# .env.example — Configurações do Servidor de Push
#
# Para usar:
# 1. Copie este arquivo e renomeie a cópia para `.env`
# 2. Preencha os valores abaixo com as suas chaves e email
# ============================================================

# Chave pública VAPID gerada via `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=SUA_CHAVE_PUBLICA_AQUI

# Chave privada VAPID gerada via `npx web-push generate-vapid-keys`
VAPID_PRIVATE_KEY=SUA_CHAVE_PRIVADA_AQUI

# Seu e-mail de contato (o serviço de push do navegador do usuário
# usa esse e-mail para entrar em contato caso haja abusos)
VAPID_EMAIL=mailto:seu-email@dominio.com

# Porta do servidor (padrão 3000 caso não definida)
PORT=3000
